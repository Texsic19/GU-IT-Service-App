# Copy to secrets.toml for local runs, or paste this entire block into
# Streamlit Community Cloud → your app → Settings → Secrets.

[database]
DB_URL = "postgresql://USER:PASSWORD@HOST:5432/DATABASE"

[gemini]
GEMINI_API_KEY = "your-google-ai-key"
# Optional: override the model used by ai_utils.py
MODEL = "gemini-2.5-flash"

[auth]
staff_password = "choose-a-strong-password"

